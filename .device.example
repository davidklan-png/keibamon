# .device -- machine-local identity (copy to `.device`, which is gitignored).
# One per checkout. Read by tools/whichdevice.py and by agents before acting.
# role must be one of: capture-pc | mac-dev | cowork-sandbox
role = mac-dev
hostname = my-macbook

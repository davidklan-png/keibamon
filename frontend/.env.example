# ADR-0007 Phase 1 — Clerk auth + social Worker.
# Copy to frontend/.env and fill in. Vite only exposes keys prefixed with VITE_.

# Clerk publishable key (pk_...). Get it from Clerk Dashboard → API Keys.
# Without it, the app builds but auth gate renders without a Clerk session.
VITE_CLERK_PUBLISHABLE_KEY=

# Base URL of the deployed social Worker (keibamon-social), WITHOUT a trailing
# slash. Local dev: http://127.0.0.1:8787 (default `wrangler dev`).
# Prod (Phase 1): https://keibamon-social.<your-subdomain>.workers.dev
VITE_SOCIAL_API_BASE=

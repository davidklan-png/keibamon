.venv/
__pycache__/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.DS_Store

# Machine-local device identity (one per checkout; see .device.example)
.device

# Local data lake and model artifacts
data/raw/**
data/normalized/**
data/features/**
data/marts/**
data/mlruns/**
data/pattern_of_life_runner_z.parquet
!data/raw/.gitkeep
!data/normalized/.gitkeep
!data/features/.gitkeep
!data/marts/.gitkeep
!data/mlruns/.gitkeep

# JV-Data spec reference (redistribution-restricted — never commit the PDFs).
# Keep the explanatory README tracked; ignore everything else under reference/.
reference/**
!reference/README.md

# Frontend
frontend/node_modules/
frontend/dist/
frontend/tsconfig.tsbuildinfo
# Playwright runtime artifacts (baselines live in tests/visual/visual.spec.ts-snapshots/)
frontend/test-results/
# Vite build output (SPA lives at /app/ via the existing ASSETS binding)
splash/app/

# Root test harness (racing Worker parity suite)
node_modules/
.cache/


# wrangler files
.wrangler
.dev.vars*
!.dev.vars.example
.env*
!.env.example

# Capture-PC + Mac Python venvs and runtime logs (machine-local)
venv32/
venv64/
logs/

# JV-Link manifest airlock (per-card manifests are machine-local, never commit)
tools/jravan/manifests/

# Claude Code / Cowork machine-local settings (keeps both trees clean for the PC mirror)
.claude/settings.local.json

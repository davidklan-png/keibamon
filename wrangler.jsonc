{
  // Static-assets Worker that serves the keibamon.com splash page.
  // Name must match the existing Worker (keibamon.<subdomain>.workers.dev).
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "keibamon",
  "compatibility_date": "2026-06-11",
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": "./splash"
  },
  "compatibility_flags": [
    "nodejs_compat"
  ]
}
